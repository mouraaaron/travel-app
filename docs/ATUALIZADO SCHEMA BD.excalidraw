    {
      "id": "9I0o_b4cR5KoNMx-qr9Rz",
      "type": "text",
      "x": 2426.8101221360016,
      "y": 819.2107493839452,
      "width": 666.4194946289062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
