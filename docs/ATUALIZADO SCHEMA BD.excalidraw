      "seed": 824704917,
      "version": 213,
      "versionNonce": 999104059,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1784040151921,
      "link": null,
      "locked": false,
      "text": "Simplifica o banco (Não tem necessidade de criar uma entidade nova)\nGarante que o exchange rate está sempre atualizado\nBusca por voos não terá um número alto de requisições no MVP\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Simplifica o banco (Não tem necessidade de criar uma entidade nova)\nGarante que o exchange rate está sempre atualizado\nBusca por voos não terá um número alto de requisições no MVP\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "F9opOc3qxj9USmk2QBoOf",
      "type": "text",
      "x": 2478.3683882304695,
      "y": 936.0311138951593,
      "width": 489.7796325683594,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 367246837,
      "version": 163,
      "versionNonce": 1711748853,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1784040151921,
      "link": null,
      "locked": false,
      "text": "Se a API cair, a requisição de flights cai também...",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Se a API cair, a requisição de flights cai também...",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "V_C81GUpSn3WixxVXx7L7",
      "type": "text",
      "x": 2278.8379196757273,
      "y": 666.1899822590382,
      "width": 1404.5992431640625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 911118421,
      "version": 260,
      "versionNonce": 1608440635,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784040947074,
      "link": null,
      "locked": false,
      "text": "Cálculo do exchange rate:\n1. Cache no Supabase (exchange_rates: moeda, taxa, data): se já tem uma cotação buscada hoje, usa ela — sem chamar a API externa de novo.\n2. Se não tem cotação de hoje, tenta buscar na AwesomeAPI e salva no cache.\n3. Se a API falhar (fora do ar, timeout, erro), em vez de quebrar a busca, cai pra última cotação salva no cache.\n4. Se o cache estiver completamente vazio, assume rate de 5.4.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cálculo do exchange rate:\n1. Cache no Supabase (exchange_rates: moeda, taxa, data): se já tem uma cotação buscada hoje, usa ela — sem chamar a API externa de novo.\n2. Se não tem cotação de hoje, tenta buscar na AwesomeAPI e salva no cache.\n3. Se a API falhar (fora do ar, timeout, erro), em vez de quebrar a busca, cai pra última cotação salva no cache.\n4. Se o cache estiver completamente vazio, assume rate de 5.4.",
      "autoResize": true,
      "lineHeight": 1.25
    },
